{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "{**", "close": "**}" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(features|subcomponents|connections|properties|flows|modes|public|private|annex)\\s*$",
    "decreaseIndentPattern": "^\\s*end\\s+"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
