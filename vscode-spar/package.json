{
  "name": "spar-aadl",
  "displayName": "AADL (spar)",
  "description": "AADL v2.2 language support with live architecture visualization",
  "publisher": "pulseengine",
  "version": "0.7.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pulseengine/spar"
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:aadl",
    "onCommand:spar.showDiagram",
    "onCommand:spar.selectRoot",
    "workspaceContains:**/*.aadl"
  ],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "aadl",
        "extensions": [
          ".aadl"
        ],
        "aliases": [
          "AADL",
          "aadl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aadl",
        "scopeName": "source.aadl",
        "path": "./syntaxes/aadl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "spar.showDiagram",
        "title": "Show Architecture Diagram",
        "category": "AADL",
        "icon": "$(circuit-board)"
      },
      {
        "command": "spar.selectRoot",
        "title": "Select Root System",
        "category": "AADL"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "spar.showDiagram",
          "when": "editorLangId == aadl",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "AADL (spar)",
      "properties": {
        "spar.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the spar binary. Leave empty to use the bundled binary or spar on PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22",
    "@types/mocha": "^10",
    "@vscode/test-electron": "^2.4.0",
    "mocha": "^10",
    "glob": "^11",
    "typescript": "^5.9.0",
    "esbuild": "^0.25.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild -- --production",
    "compile": "tsc -b",
    "esbuild": "node ./bin/esbuild.js",
    "watch": "tsc -b -w",
    "test": "node ./out/test/runTest.js",
    "package": "npx @vscode/vsce package"
  }
}
